#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_notebook_candidates="$(
    git diff --cached --name-only --diff-filter=ACMR \
        | grep -E '^scripts/notebooks/.*\.(ipynb|py)$' || true
)"

if [[ -z "${staged_notebook_candidates}" ]]; then
    exit 0
fi

if command -v direnv >/dev/null 2>&1 && [[ -f "$repo_root/.envrc" ]]; then
    direnv exec "$repo_root" python3 scripts/notebooks/jupytext_sync.py --staged --stage-updated
else
    python3 scripts/notebooks/jupytext_sync.py --staged --stage-updated
fi
