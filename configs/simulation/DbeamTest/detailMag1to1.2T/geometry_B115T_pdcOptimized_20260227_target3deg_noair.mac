# Geometry configuration - Magnetic field: 1.15T, PDC optimized on 2026-02-27
# Target fixed for 3deg campaign: (-1.2488, 0.0009, -106.9458) cm, angle 3.0 deg
# Target disabled: PDC tracking study uses tree-gun injection downstream of the
# target, so enabling the 5 mm Sn slab only adds spurious multiple scattering.
/control/getEnv SMSIMDIR
/samurai/geometry/Target/SetTarget false
/samurai/geometry/Target/Position -1.2488 0.0009 -106.9458 cm
/samurai/geometry/Target/Angle 3.0 deg
/samurai/geometry/PDC/Angle 69 deg
/samurai/geometry/PDC/Position1 70 0 400 cm
/samurai/geometry/PDC/Position2 70 0 500 cm
/samurai/geometry/Dump/SetDump false
/samurai/geometry/Dump/Angle 36.67 deg
/samurai/geometry/Dump/Position -0.93 -25.00 0.00 cm
/samurai/geometry/NEBULA/ParameterFileName {SMSIMDIR}/configs/simulation/geometry/NEBULA_Dayone.csv
/samurai/geometry/NEBULA/DetectorParameterFileName {SMSIMDIR}/configs/simulation/geometry/NEBULA_Detectors_Dayone.csv
/samurai/geometry/Dipole/Angle 30 deg
/samurai/geometry/Dipole/FieldFile {SMSIMDIR}/configs/simulation/geometry/filed_map/180703-1,15T-3000.table
/samurai/geometry/Dipole/FieldFactor 1
/samurai/geometry/FillAir false
/samurai/geometry/Update
