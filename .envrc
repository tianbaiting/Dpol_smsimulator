# [EN] direnv runs in a child shell; ensure micromamba binary is visible even when tmux PATH is stale. / [CN] direnv 在子 shell 中执行；即使 tmux 的 PATH 过期，也确保能找到 micromamba 二进制。
PATH_add "$HOME/.local/bin"

# [EN] Activate anaroot only when micromamba is resolvable to avoid hard failure on directory enter. / [CN] 只有在能解析到 micromamba 时才激活 anaroot，避免进入目录时硬失败。
if command -v micromamba >/dev/null 2>&1; then
    eval "$(micromamba shell hook --shell zsh)"
    micromamba activate anaroot-env
else
    echo "direnv: warning: micromamba not found, skip anaroot-env activation" >&2
fi

# 3. 加载项目设置 (保持你原有的，通常用于设置 Geant4 数据路径等)
if [[ -f ./setup.sh ]]; then
    source ./setup.sh
fi
